# A4 Office production environment template.
# Copy this file to .env on the production server only. Never commit the real .env.
#
#   cp .env.production.example .env
#   sed -i "s|^JWT_SECRET=.*|JWT_SECRET=$(openssl rand -hex 32)|" .env
#   sed -i "s|^RETURN_QR_SECRET=.*|RETURN_QR_SECRET=$(openssl rand -hex 32)|" .env
#   chmod 600 .env
#
# Change a4office.cloud below if the production domain is different.

# --- SERVER RUNTIME ---
NODE_ENV=production
PORT=5000
# Keep the Node.js server private; Nginx is the public entry point.
HOST=127.0.0.1
APP_DOMAIN=a4office.cloud
APP_URL=https://a4office.cloud

# Required: generate at least 32 random characters. Blank intentionally fails startup.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Required: use a different secret from JWT_SECRET.
RETURN_QR_SECRET=

# --- HTTP SECURITY AND RATE LIMITS ---
# Comma-separated explicit HTTP(S) origins are supported. Wildcard is rejected in production.
CORS_ORIGIN=https://a4office.cloud
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1500
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
# The application is behind one local Nginx reverse proxy.
TRUST_PROXY=loopback

# --- DATABASE ---
# Paths are relative to the server directory. Both paths must match in production.
SQLITE_DB_PATH=./src/db/a4_pos.db
PRODUCTION_SQLITE_DB_PATH=./src/db/a4_pos.db
# Database reset and demo accounts must always remain disabled in production.
ALLOW_DATABASE_RESET=false
SEED_DEMO_USERS=false
BOOTSTRAP_ADMIN_PASSWORD=admin123

# --- BACKUPS AND GRACEFUL SHUTDOWN ---
# BACKUP_DIR is relative to the repository root.
BACKUP_DIR=./backups
BACKUP_RETENTION=10
SHUTDOWN_TIMEOUT_MS=10000

# --- SERVER-SIDE PDF EXPORT ---
CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
PDF_TIMEOUT_MS=30000
PDF_MAX_CONCURRENCY=2
PDF_MAX_RECORDS=100

# --- CLIENT BUILD ---
# Keep empty when the frontend and /api are served from the same domain through Nginx.
# Do not append /api when setting a separate API origin.
VITE_API_BASE_URL=
