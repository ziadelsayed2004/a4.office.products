# Production reference only. Copy to .env on the server and replace placeholders.
NODE_ENV=production
PORT=5000

# Generate at least 32 random characters. A blank value intentionally makes startup fail closed.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Generate a different random value containing at least 32 characters.
RETURN_QR_SECRET=
RETURN_AUTHORIZATION_TTL_HOURS=24

# Explicit HTTP(S) origins only; wildcard is rejected in production.
CORS_ORIGIN=https://pos.example.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1500
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
TRUST_PROXY=loopback

SQLITE_DB_PATH=./src/db/a4_pos.db
PRODUCTION_SQLITE_DB_PATH=./src/db/a4_pos.db
ALLOW_DATABASE_RESET=false
SEED_DEMO_USERS=false

BACKUP_DIR=./backups
BACKUP_RETENTION=10
SHUTDOWN_TIMEOUT_MS=10000

# Empty means same-origin through Nginx.
VITE_API_BASE_URL=
