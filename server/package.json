{
  "name": "a4-office-products-pos-server",
  "version": "1.0.0",
  "description": "Backend API server for A4 Office Products POS Platform",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "node scripts/check-syntax.mjs",
    "check:syntax": "node scripts/check-syntax.mjs",
    "test": "npm run lint && npm run test:unit && npm run test:schema && npm run test:smoke && npm run test:services",
    "test:unit": "node src/tests/reset-safety.test.js",
    "test:schema": "node src/tests/schema.test.js",
    "test:smoke": "node src/tests/smoke.test.js",
    "test:services": "node src/tests/services.test.js",
    "db:setup": "node src/db/setup.js",
    "db:reset": "node src/db/reset.js",
    "db:backup": "node src/utils/run-backup.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
