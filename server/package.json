{
  "name": "a4-office-products-pos-server",
  "version": "1.0.0",
  "description": "Backend API server for A4 Office Products POS Platform",
  "main": "src/server.js",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "oxlint src && node scripts/check-syntax.mjs",
    "check:syntax": "node scripts/check-syntax.mjs",
    "db:setup": "node src/db/setup.js",
    "db:migrate": "node src/db/setup.js",
    "db:reset": "node src/db/reset.js --confirm-reset",
    "db:verify": "node src/db/verify.js",
    "db:backup": "node src/utils/run-backup.js",
    "admin:bootstrap": "node src/db/bootstrap-admin.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "puppeteer-core": "^24.16.0",
    "sqlite3": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "oxlint": "^1.73.0"
  }
}
