# A4 Office Products environment template
# Copy this file to .env for local development. Never commit the real .env file.

# --- SERVER RUNTIME ---
NODE_ENV=development
PORT=5000
HOST=127.0.0.1
APP_DOMAIN=localhost
APP_URL=http://localhost:5173

# Replace this value with a long, random secret before any production deployment.
JWT_SECRET=development_only_change_me_before_production
JWT_EXPIRES_IN=7d

# Signs one-time return authorization QR cards. Use a distinct 32+ character secret in production.
RETURN_QR_SECRET=development_only_return_qr_secret_change_me
RETURN_AUTHORIZATION_TTL_HOURS=24

# Browser origin allowed to call the API.
CORS_ORIGIN=http://localhost:5173

# API rate limiting: 15 minutes and 1,500 requests per client.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1500

# Login has a lower independent limit.
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# The development server is reached directly. Production behind local Nginx uses loopback.
TRUST_PROXY=false

# --- DATABASE ---
# Paths are relative to the server directory unless an absolute path is supplied.
# Keep the local/dev marker in the development filename so the reset guard can verify it.
SQLITE_DB_PATH=./src/db/a4_pos.local.db
PRODUCTION_SQLITE_DB_PATH=./src/db/a4_pos.db

# Development only. Reset still requires --confirm-reset and is always blocked in production.
ALLOW_DATABASE_RESET=true

# Creates admin/admin123 and cashier/cashier123 in development only.
# Production validation requires this to be false.
SEED_DEMO_USERS=true

# --- BACKUPS AND SHUTDOWN ---
# BACKUP_DIR is resolved from the repository root; only valid backups count toward retention.
BACKUP_DIR=./backups
BACKUP_RETENTION=10
SHUTDOWN_TIMEOUT_MS=10000

# Server-side A4 PDF export. Install Chromium separately on Linux.
CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
PDF_TIMEOUT_MS=30000
PDF_MAX_CONCURRENCY=2
PDF_MAX_RECORDS=100

# --- CLIENT BUILD ---
# API origin only; client requests already include /api. Do not append /api here.
VITE_API_BASE_URL=http://localhost:5000
